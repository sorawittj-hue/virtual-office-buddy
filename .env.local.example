# ── Local Self-Hosted Setup ────────────────────────────────────────────────────
# Copy this file to .env for local development / self-hosted on the same machine
# as Hermes Agent.
#
#   cp .env.local.example .env
#
# Then run:
#   bun install && bun run build && bunx wrangler dev --port 3000 --local

# Hermes Agent API URL (default port when running locally)
HERMES_API_URL=http://localhost:9119

# API Key — leave blank unless you set API_SERVER_KEY in Hermes .env
HERMES_API_KEY=

# (Optional) Telegram bridge — only needed if using WS bridge mode
# TELEGRAM_BOT_TOKEN=your_bot_token_here
# ALLOWED_CHAT_IDS=123456789
# WS_PORT=18789
# WS_SECRET=your-random-secret-key-here
