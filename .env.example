# ── Prism Dashboard — Auto-connect on first launch ────────────────────────────
# ตั้งค่านี้แล้วไม่ต้องเข้า Gateway page เพื่อ connect เอง
# VITE_ prefix = ถูก inject เข้า browser bundle โดย Vite
VITE_DEFAULT_API_URL=http://localhost:9119
VITE_DEFAULT_API_KEY=

# ── Telegram Bot ──────────────────────────────────────────────────────────────
# รับ token จาก @BotFather ใน Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here

# ── WebSocket Server ───────────────────────────────────────────────────────────
WS_PORT=18789

# Secret key สำหรับยืนยันตัวตน WebSocket client
# แนะนำ: openssl rand -hex 32
WS_SECRET=your-random-secret-key-here

# ── Authorization ──────────────────────────────────────────────────────────────
# Telegram chat IDs ที่อนุญาต (คั่นด้วย comma)
# วิธีหา chat ID: ส่งข้อความให้ bot แล้วดู logs ("chatId=...")
ALLOWED_CHAT_IDS=123456789

# ── Hermes LLM via OpenRouter (แนะนำ) ─────────────────────────────────────────
# สมัครฟรีได้ที่ https://openrouter.ai
OPENROUTER_API_KEY=sk-or-your-openrouter-key-here

# Model ที่ใช้ (ลงท้าย :free = ฟรี)
# ดู models ทั้งหมดได้ที่ https://openrouter.ai/models?q=hermes
HERMES_MODEL=nousresearch/hermes-3-llama-3.1-405b:free

# ── Anthropic Claude (optional fallback) ──────────────────────────────────────
# ถ้าไม่มี OPENROUTER_API_KEY จะใช้ Claude แทน
# ANTHROPIC_API_KEY=sk-ant-your-api-key-here

# ── Rate Limiting ──────────────────────────────────────────────────────────────
# จำกัดคำสั่งต่อนาทีต่อ chat (default: 5)
# RATE_LIMIT_PER_MIN=5
