# Local development example for Virtual Office Buddy.
# Copy to .env for a same-machine frontend, proxy, Hermes Agent, and optional Telegram bridge.

OPENROUTER_API_KEY=
OPENAI_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=nousresearch/hermes-3-llama-3.1-405b:free

VITE_HERMES_LOCAL_URL=http://localhost:9119
VITE_DEFAULT_CONNECTION_MODE=standalone

PRISM_PROXY_PORT=3001
PRISM_PROXY_SECRET=
PRISM_BROWSER_PROXY_TOKEN=
VITE_PRISM_PROXY_AUTH_TOKEN=
PRISM_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173
PRISM_RATE_LIMIT_PER_MIN=30
PRISM_MAX_BODY_BYTES=1048576

TELEGRAM_BOT_TOKEN=
ALLOWED_CHAT_IDS=
WS_PORT=18789
WS_SECRET=
RATE_LIMIT_PER_MIN=5
MAX_COMMAND_CHARS=4000
