# Virtual Office Buddy environment example.
# Copy to .env and fill in only the values you need. Do not commit real secrets.

# OpenRouter API key for standalone chat through proxy-server.js.
OPENROUTER_API_KEY=

# Optional OpenAI API key. Used when OPENROUTER_API_KEY is not set or when OPENROUTER_BASE_URL points to OpenAI-compatible APIs.
OPENAI_API_KEY=

# OpenAI-compatible base URL. Defaults to OpenRouter.
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Default model used by proxy-server.js.
OPENROUTER_MODEL=nousresearch/hermes-3-llama-3.1-405b:free

# Browser-visible local Hermes Agent URL. VITE_ values are exposed to the frontend bundle.
VITE_HERMES_LOCAL_URL=http://localhost:9119

# Frontend default mode: standalone or hermes.
VITE_DEFAULT_CONNECTION_MODE=standalone

# Local proxy port.
PRISM_PROXY_PORT=3001

# Bearer secret for proxy API requests. Required when NODE_ENV=production.
PRISM_PROXY_SECRET=

# Comma-separated allowed browser origins for proxy CORS.
PRISM_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173

# Per-IP /api/chat requests per minute.
PRISM_RATE_LIMIT_PER_MIN=30

# Max JSON body size in bytes for proxy requests.
PRISM_MAX_BODY_BYTES=1048576

# Telegram bot token from BotFather.
TELEGRAM_BOT_TOKEN=

# Comma-separated Telegram chat IDs allowed to use the bot. Required in production.
ALLOWED_CHAT_IDS=

# WebSocket bridge port.
WS_PORT=18789

# WebSocket shared secret. Required in production.
WS_SECRET=

# Telegram and WebSocket bridge messages per minute.
RATE_LIMIT_PER_MIN=5

# Maximum command/message length accepted by telegram-bridge.js.
MAX_COMMAND_CHARS=4000
