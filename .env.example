# ── Telegram Bot ──────────────────────────────────────────────────────────────
# รับ token จาก @BotFather ใน Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here

# ── WebSocket Server ───────────────────────────────────────────────────────────
WS_PORT=18789

# Secret key สำหรับยืนยันตัวตน WebSocket client
# ตั้งค่านี้แล้ว Web App จะต้องใส่ key เมื่อเชื่อมต่อ
# แนะนำ: สร้าง random string เช่น openssl rand -hex 32
WS_SECRET=your-random-secret-key-here

# ── Authorization ──────────────────────────────────────────────────────────────
# รายการ Telegram chat IDs ที่อนุญาต (คั่นด้วย comma)
# วิธีหา chat ID: ส่งข้อความให้ bot แล้วดูใน logs ("chatId=...")
# ถ้าไม่ตั้งค่า = ทุกคนส่งคำสั่งได้ (ไม่ปลอดภัย!)
ALLOWED_CHAT_IDS=123456789,987654321

# ── Anthropic AI (optional) ────────────────────────────────────────────────────
# ถ้าตั้งค่า: Claude AI จะวางแผนขั้นตอนจริงๆ สำหรับทุกคำสั่ง
# ถ้าไม่ตั้ง: ใช้ hardcoded fallback plans
ANTHROPIC_API_KEY=sk-ant-your-api-key-here

# จำกัดจำนวนคำสั่งต่อนาทีต่อ chat (default: 5)
# RATE_LIMIT_PER_MIN=5
